# HETU SafePlay - Environment variables
# Copy to .env and fill in values for local development

# ENV=production for Render (CORS rajoitetaan leevinhetuntarkistuskone.fi). Jätä tyhjäksi paikallisesti.
# ENV=

# Fernet encryption key (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
SALAUSAVAIN=

# PostgreSQL connection string (e.g. postgresql://user:pass@localhost:5432/hetu_safeplay)
DATABASE_URL=
